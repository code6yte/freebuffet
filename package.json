{
  "name": "freebuffet",
  "version": "0.1.1",
  "description": "All-you-can-eat LLM providers — set up 165+ providers for OpenCode, Codex, Claude Code & Antigravity CLI",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "fb": "dist/index.js",
    "freebuffet": "dist/index.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./providers": {
      "types": "./dist/providers.d.ts",
      "default": "./dist/providers.js"
    },
    "./health": {
      "types": "./dist/health.d.ts",
      "default": "./dist/health.js"
    },
    "./config": {
      "types": "./dist/config.d.ts",
      "default": "./dist/config.js"
    },
    "./configs": {
      "types": "./dist/configs/index.d.ts",
      "default": "./dist/configs/index.js"
    }
  },
  "scripts": {
    "build": "bun run build:lib && bun run build:bundle",
    "build:bundle": "bun build ./src/index.ts --outdir ./dist --target node",
    "build:lib": "tsc --outDir dist",
    "dev": "bun run ./src/index.ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run build",
    "prepack": "bun run build"
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "keywords": [
    "freebuffet",
    "llm",
    "provider",
    "opencode",
    "codex",
    "claude-code",
    "antigravity",
    "ai-coding-agent"
  ],
  "license": "MIT",
  "author": {
    "name": "code6yte",
    "url": "https://github.com/code6yte"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/code6yte/freebuffet.git"
  },
  "bugs": {
    "url": "https://github.com/code6yte/freebuffet/issues"
  },
  "homepage": "https://github.com/code6yte/freebuffet#readme",
  "engines": {
    "node": ">=18",
    "bun": ">=1.0"
  },
  "dependencies": {
    "@clack/prompts": "^0.10.1",
    "freebuffet": "^0.1.0",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.0"
  }
}
